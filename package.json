{
  "name": "harvest-scan",
  "version": "1.0.1",
  "description": "Fast, plugin-driven security & code-quality scanner with a single 0-100 score, SARIF output, autofix, and a GitHub Action.",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "harvest": "cli.js",
    "harvest-scan": "cli.js"
  },
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "lint": "eslint \"**/*.{js,ts}\" --fix",
    "lint:fix": "eslint \"**/*.{js,ts}\" --config .eslintrc.cjs --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "start-api": "node ./src/api.js",
    "scan": "node ./cli.js",
    "logo": "node scripts/render-logo.mjs",
    "prepublishOnly": "npm test",
    "postinstall": "node ./postinstall.cjs",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "cli.js",
    "reporter.js",
    "history.js",
    "doctor.js",
    "outdated.js",
    "plugin-manager.js",
    "postinstall.cjs",
    "src/api.js",
    "packages/core/index.d.ts",
    "packages/core/package.json",
    "packages/core/src/**/*.js",
    "packages/core/plugins/**/*.js",
    ".github/openapi.yaml"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./api": {
      "import": "./src/api.js"
    }
  },
  "keywords": [
    "scanner",
    "quality",
    "cli",
    "antivirus",
    "cybersecurity",
    "js",
    "cli-tool",
    "antivirus",
    "scan",
    "terminal",
    "api",
    "fast",
    "easy",
    "module",
    "scanning",
    "malware-analysis",
    "malware analysis",
    "security",
    "vulnerability-scanner",
    "dependency-scanner",
    "sast",
    "static-analysis",
    "nodejs",
    "npm",
    "js-security",
    "code-quality",
    "devsecops",
    "continuous-integration",
    "ci",
    "scan-tool",
    "audit",
    "dependency-audit",
    "lint",
    "code-scanner",
    "file-scanner",
    "directory-scanner"
  ],
  "author": "Aditya Pandey [https://github.com/Aditya060806]",
  "homepage": "https://github.com/Aditya060806/Harvest#readme",
  "bugs": {
    "url": "https://github.com/Aditya060806/Harvest/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Aditya060806/Harvest"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Aditya060806"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/swagger": "^6.1.1",
    "@fastify/swagger-ui": "^4.2.0",
    "@nodesecure/js-x-ray": "^15.1.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "compromise": "^14.15.1",
    "fastify": "^4.29.1",
    "figlet": "^1.8.1",
    "globby": "^14.0.2",
    "node-fetch": "^3.3.2",
    "typhonjs-escomplex": "^0.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^59.0.1",
    "globals": "^16.2.0",
    "jest": "^30.0.2",
    "jest-cli": "^30.0.2",
    "prettier": "^3.6.2",
    "sharp": "^0.35.3"
  }
}
