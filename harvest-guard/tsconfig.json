{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "out",
		"skipLibCheck": true,          // così ignori eventuali d.ts terzi
    	"moduleResolution": "node16",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/test/**", "node_modules", "out"]
}
